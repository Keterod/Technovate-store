rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para el catálogo de productos (digizone_productos)
    match /digizone_productos/{productId} {
      // Cualquiera puede ver los productos disponibles
      allow read: if true;
      
      // Solo usuarios autenticados (o administradores) pueden registrar, editar o eliminar productos.
      // Puedes ajustar esto para requerir un correo o rol administrativo específico.
      allow write: if request.auth != null;
    }

    // Reglas para el historial de conversaciones del asistente (assistant_history)
    match /assistant_history/{historyId} {
      // Permitir la creación de nuevos registros (logs de conversación) de forma pública/anónima
      allow create: if true;
      
      // Prohibir la lectura, modificación o eliminación pública de los registros para proteger la privacidad del usuario
      allow read, update, delete: if request.auth != null;
    }

    // Reglas para la configuración de la tienda (coordenadas, ubicación, etc.)
    match /configuracion/{configId} {
      // Lectura permitida para obtener ubicación de la tienda en el mapa
      allow read: if true;
      
      // Solo escritura para administradores autenticados
      allow write: if request.auth != null;
    }
  }
}
